# Ansible MCP Server Environment Configuration

# ============================================
# Docker Compose Settings
# ============================================

# Port for SSE (Server-Sent Events) transport
# Default: 8000
MCP_PORT=8000

# MCP Server Host (for SSE mode)
# Default: 0.0.0.0
MCP_HOST=0.0.0.0

# ============================================
# Ansible Configuration
# ============================================

# Path to local Ansible configuration directory
# This directory will be mounted to /workspace in the container
# Default: current directory (.)
ANSIBLE_CONFIG_DIR=.

# Path to SSH keys for Ansible
# Mount location for SSH credentials
# Default: current directory (.)
SSH_KEY_PATH=.

# Ansible configuration file path (optional)
# If set, ANSIBLE_CONFIG environment variable will be set in container
# ANSIBLE_CONFIG=/etc/ansible/ansible.cfg

# Inventory file path (optional)
# ANSIBLE_INVENTORY=/etc/ansible/inventory

# ============================================
# Ansible MCP Server Configuration
# ============================================

# Project root for Ansible MCP operations
# Default: /workspace (mounted directory in container)
# MCP_ANSIBLE_PROJECT_ROOT=/workspace

# Project name for MCP configuration
# MCP_ANSIBLE_PROJECT_NAME=ansible-mcp

# Ansible roles path (colon-separated for multiple paths)
# MCP_ANSIBLE_ROLES_PATH=/workspace/roles

# Ansible collections paths (colon-separated for multiple paths)
# MCP_ANSIBLE_COLLECTIONS_PATHS=/workspace/collections

# ============================================
# Python/Runtime Settings
# ============================================

# Python environment
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1

# ============================================
# Transport Mode
# ============================================

# MCP Transport mode: stdio or sse
# stdio = Standard input/output (default, for local/integrated use)
# sse = Server-Sent Events (for remote/network access)
# Default: stdio
# MCP_TRANSPORT=stdio

# ============================================
# Logging & Debug
# ============================================

# Debug mode (0 or 1)
# Set to 1 to enable debug logging
# DEBUG=0

# Log level: DEBUG, INFO, WARNING, ERROR
# LOG_LEVEL=INFO

# ============================================
# Docker Compose Profiles
# ============================================

# To use optional services, include them in COMPOSE_PROFILES
# Example: COMPOSE_PROFILES=sse,control
# Available profiles:
#   - sse: Enable SSE transport service
#   - control: Enable Ansible control node
# COMPOSE_PROFILES=
